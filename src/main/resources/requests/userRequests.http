### Register new user
POST http://localhost:8080/api/users/register
Content-Type: application/json

{
  "username": "Jasper",
  "email": "jasper@dnd.com",
  "password": "1234"
}

### Log in to user
POST http://localhost:8080/api/users/login
Content-Type: application/json

{
  "usernameOrEmail": "Jasper",
  "password": "1234"
}

> {%
    client.global.set("auth_token", response.body.token);
    client.log("Successfully saved JWT token to global variables!");
%}